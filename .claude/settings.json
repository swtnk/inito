      "Bash(uv python *)",
      "Bash(uvx twine *)",
      "Bash(./scripts/check_all.sh)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(git restore *)",
      "Bash(python3 -c *)",
      "Bash(python -c *)",
      "WebFetch(domain:api.github.com)",
